{
  "name": "auralis-music-player",
  "version": "1.0.0",
  "private": true,
  "description": "Glass music player with a local music engine and database API.",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "check": "node --check server/index.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "des.js": "^1.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.0",
    "youtubei.js": "^17.0.1"
  }
}
