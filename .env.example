# ═══════════════════════════════════════════════════
#  Auralis Music Player — Example Environment File
#  Copy this to .env and fill in your values.
#  This file IS safe to commit. .env is NOT.
# ═══════════════════════════════════════════════════

PORT=4173
MONGODB_URI=mongodb://127.0.0.1:27017/auralis
VITE_API_URL=http://localhost:4173
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
YTDLP_TIMEOUT_MS=25000
ITUNES_API_BASE=https://itunes.apple.com
RATE_LIMIT_MAX=200
SESSION_SECRET=replace_with_random_64_char_hex
LOG_LEVEL=info

# Optional
# YTDLP_PATH=
# YTDLP_COOKIES_FILE=
# AUDIUS_HOST=
